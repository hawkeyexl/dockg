{
  "name": "dockg",
  "version": "0.1.0",
  "description": "Deterministic knowledge graphs derived from documentation frontmatter and formatting, saved as Turtle.",
  "type": "module",
  "bin": {
    "dockg": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schemas",
    "shapes"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hawkeyexl/dockg.git"
  },
  "homepage": "https://github.com/hawkeyexl/dockg#readme",
  "bugs": {
    "url": "https://github.com/hawkeyexl/dockg/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "semantic-release": "semantic-release",
    "prepare": "husky",
    "prepublishOnly": "node scripts/check-publishable.mjs && npm run build"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json,yaml,yml}": [
      "prettier --check",
      "eslint --max-warnings=0 --no-warn-ignored"
    ]
  },
  "keywords": [
    "knowledge-graph",
    "rdf",
    "turtle",
    "skos",
    "frontmatter",
    "markdown",
    "documentation",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^15.0.0",
    "cross-spawn": "^7.0.6",
    "docmeta": "^1.3.0",
    "fast-glob": "^3.3.2",
    "github-slugger": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
    "n3": "^1.26.0",
    "picocolors": "^1.1.1",
    "rdf-validate-shacl": "^0.6.5",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/cross-spawn": "^6.0.6",
    "@types/n3": "^1.26.0",
    "@types/node": "^26.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.6",
    "semantic-release": "^25.0.3",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.9"
  }
}
